--- !u!114 &4194353960994035180
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7088533194191699387}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d28a4a5f138e4891aaa3f8b61d36cf3d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _comicText: {fileID: 2058015468347826430}
  _backButton: {fileID: 2659499379115008935}
  _nextSlideButton: {fileID: 6960200441085947029}
  _previousSlideButton: {fileID: 6552985196342519809}
  _comicScrollRect: {fileID: 6369225900502740875}
  _slideTexts:
  - "\u0418\u0437 \u043A\u0430\u0431\u0438\u043D\u044B \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u043E\u0433\u043E
    \u043A\u043E\u0440\u0430\u0431\u043B\u044F \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u0432\u0438\u0434 \u043D\u0430 \u0431\u0435\u0441\u043A\u0440\u0430\u0439\u043D\u0435\u0435
    \u043F\u043E\u043B\u0435 \u0430\u0441\u0442\u0435\u0440\u043E\u0438\u0434\u043E\u0432
    \u0438 \u0441\u0438\u044F\u044E\u0449\u0443\u044E \u0432\u0434\u0430\u043B\u0435\u043A\u0435
    \u0433\u043E\u043B\u0443\u0431\u0443\u044E \u043F\u043B\u0430\u043D\u0435\u0442\u0443.
    \u0422\u0435\u043D\u044C \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0433\u043E
    \u0430\u0441\u0442\u0435\u0440\u043E\u0438\u0434\u0430 \u043D\u0430 \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u0438\u0435
    \u043F\u043E\u0433\u043B\u043E\u0442\u0438\u043B\u0430 \u043A\u0430\u0431\u0438\u043D\u0443,
    \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u0432 \u0442\u0440\u0435\u0432\u043E\u0436\u043D\u043E
    \u043C\u0438\u0433\u0430\u0442\u044C \u043F\u0440\u0438\u0431\u043E\u0440\u044B.
    \u0429\u0438\u0442\u044B \u043D\u0430 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u043C
    \u043F\u0440\u043E\u0446\u0435\u043D\u0442\u0435. \u041E\u0434\u043D\u0430 \u043E\u0448\u0438\u0431\u043A\u0430
    \u2014 \u0438 \u0432\u0441\u0435\u043C \u043A\u043E\u043D\u0435\u0446, \u2014
    \u043F\u0440\u043E\u043D\u0435\u0441\u043B\u043E\u0441\u044C \u0432 \u0433\u043E\u043B\u043E\u0432\u0435
    \u0443 \u043F\u0438\u043B\u043E\u0442\u0430. \u0415\u0433\u043E \u043F\u0430\u043B\u044C\u0446\u044B
    \u0432\u0446\u0435\u043F\u0438\u043B\u0438\u0441\u044C \u0432 \u0448\u0442\u0443\u0440\u0432\u0430\u043B
    \u0434\u043E \u0431\u0435\u043B\u0438\u0437\u043D\u044B \u043A\u043E\u0441\u0442\u044F\u0448\u0435\u043A.
    \u0412\u043F\u0435\u0440\u0435\u0434\u0438 \u0437\u0438\u044F\u043B \u0445\u0430\u043E\u0442\u0438\u0447\u043D\u044B\u0439
    \u043B\u0430\u0431\u0438\u0440\u0438\u043D\u0442 \u0438\u0437 \u043A\u0430\u043C\u0435\u043D\u043D\u044B\u0445
    \u0433\u043B\u044B\u0431. \u0421 \u0440\u0435\u0432\u043E\u043C \u043C\u0430\u043D\u0435\u0432\u0440\u043E\u0432\u044B\u0445
    \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043B\u0435\u0439 \u043A\u043E\u0440\u0430\u0431\u043B\u044C
    \u0440\u0438\u043D\u0443\u043B\u0441\u044F \u0432 \u044D\u0442\u0443 \u0449\u0435\u043B\u044C,
    \u0435\u0434\u0432\u0430 \u0438\u0437\u0431\u0435\u0436\u0430\u0432 \u0441\u0442\u043E\u043B\u043A\u043D\u043E\u0432\u0435\u043D\u0438\u044F.
    \u0421\u0432\u0438\u0441\u0442 \u0440\u0430\u0441\u0441\u0435\u043A\u0430\u0435\u043C\u043E\u0433\u043E
    \u043A\u0430\u043C\u043D\u044F \u043E\u0433\u043B\u0443\u0448\u0430\u043B."
  - "\u041A\u043E\u0440\u0430\u0431\u043B\u044C \u0432\u0438\u0440\u0442\u0443\u043E\u0437\u043D\u043E
    \u043F\u0440\u043E\u043B\u0435\u0442\u0430\u0435\u0442 \u043C\u0435\u0436\u0434\u0443
    \u0434\u0432\u0443\u043C\u044F \u0441\u0442\u0430\u043B\u043A\u0438\u0432\u0430\u044E\u0449\u0438\u043C\u0438\u0441\u044F
    \u0430\u0441\u0442\u0435\u0440\u043E\u0438\u0434\u0430\u043C\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u043A\u0440\u043E\u0448\u0430\u0442\u0441\u044F \u0443 \u043D\u0435\u0433\u043E
    \u0437\u0430 \u0441\u043F\u0438\u043D\u043E\u0439. \u042D\u0442\u043E \u0431\u044B\u043B
    \u0431\u0435\u0437\u0443\u043C\u043D\u044B\u0439 \u0442\u0430\u043D\u0435\u0446.
    \u0421 \u0432\u0438\u0437\u0433\u043E\u043C \u0438 \u0441\u043A\u0440\u0435\u0436\u0435\u0442\u043E\u043C
    \u0430\u0441\u0442\u0435\u0440\u043E\u0438\u0434\u044B \u0441\u0442\u0430\u043B\u043A\u0438\u0432\u0430\u043B\u0438\u0441\u044C
    \u043F\u0440\u044F\u043C\u043E \u043F\u043E \u043A\u0443\u0440\u0441\u0443, \u0437\u0430\u0441\u044B\u043F\u0430\u044F
    \u043F\u0443\u0442\u044C \u043E\u0441\u0442\u0440\u044B\u043C\u0438 \u043E\u0441\u043A\u043E\u043B\u043A\u0430\u043C\u0438.
    \u041A\u043E\u0440\u0430\u0431\u043B\u044C \u0431\u0440\u043E\u0441\u0430\u043B\u043E
    \u0438\u0437 \u0441\u0442\u043E\u0440\u043E\u043D\u044B \u0432 \u0441\u0442\u043E\u0440\u043E\u043D\u0443.
    \u041F\u043E\u0447\u0442\u0438! \u0415\u0449\u0435 \u043E\u0434\u0438\u043D!
    \u2014 \u043C\u043E\u0437\u0433 \u0430\u043D\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043B
    \u0442\u0440\u0430\u0435\u043A\u0442\u043E\u0440\u0438\u0438 \u0431\u044B\u0441\u0442\u0440\u0435\u0435
    \u0441\u0432\u0435\u0442\u0430. \u0420\u0435\u0437\u043A\u0438\u0439 \u043A\u0440\u0435\u043D
    \u0432\u043D\u0438\u0437, \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0439 \u0433\u0443\u043B
    \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043B\u0435\u0439, \u0438 \u043E\u0433\u0440\u043E\u043C\u043D\u044B\u0439
    \u0431\u0443\u043B\u044B\u0436\u043D\u0438\u043A \u043F\u0440\u043E\u043D\u043E\u0441\u0438\u043B\u0441\u044F
    \u0432 \u0441\u0430\u043D\u0442\u0438\u043C\u0435\u0442\u0440\u0430\u0445 \u043D\u0430\u0434
    \u043A\u0430\u0431\u0438\u043D\u043E\u0439. \u041A\u0430\u0437\u0430\u043B\u043E\u0441\u044C,
    \u0441\u0430\u043C\u0430 \u0432\u0441\u0435\u043B\u0435\u043D\u043D\u0430\u044F
    \u043F\u044B\u0442\u0430\u0435\u0442\u0441\u044F \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
    \u044D\u0442\u043E\u0442 \u043E\u0434\u0438\u043D\u043E\u043A\u0438\u0439 \u043A\u043E\u0440\u0430\u0431\u043B\u044C.\r"
  - "\u041A\u043E\u0440\u0430\u0431\u043B\u044C \u0432\u044B\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F
    \u0438\u0437 \u043F\u043E\u044F\u0441\u0430 \u0430\u0441\u0442\u0435\u0440\u043E\u0438\u0434\u043E\u0432.
    \u041F\u043B\u0430\u043D\u0435\u0442\u0430 \u0412\u0430\u043B\u043B\u043E\u0440\u0430
    \u0432\u0438\u0434\u043D\u0430 \u0441\u043E\u0432\u0441\u0435\u043C \u0431\u043B\u0438\u0437\u043A\u043E,
    \u043E\u0433\u0440\u043E\u043C\u043D\u0430\u044F \u0438 \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u0430\u044F,
    \u043D\u043E \u043C\u0435\u0436\u0434\u0443 \u043D\u0435\u0439 \u0438 \u043A\u043E\u0440\u0430\u0431\u043B\u0435\u043C
    \u2014 \u043B\u0438\u0448\u044C \u0431\u0435\u0437\u0434\u043E\u043D\u043D\u0430\u044F,
    \u043F\u0443\u0441\u0442\u0430\u044F \u0442\u0438\u0448\u0438\u043D\u0430. \u041E\u0433\u043B\u0443\u0448\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0440\u0435\u0432 \u043A\u0430\u043C\u043D\u0435\u0439 \u043E\u0441\u0442\u0430\u043B\u0441\u044F
    \u043F\u043E\u0437\u0430\u0434\u0438. \u0421 \u0442\u0438\u0445\u0438\u043C \u0433\u0443\u043B\u043E\u043C
    \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u043B\u0435\u0439 \u043A\u043E\u0440\u0430\u0431\u043B\u044C
    \u0432\u044B\u0448\u0435\u043B \u043D\u0430 \u0447\u0438\u0441\u0442\u044B\u0439
    \u043A\u0443\u0440\u0441. \u041D\u0430 \u0434\u0438\u0441\u043F\u043B\u0435\u0435
    \u0432\u0441\u043F\u044B\u0445\u043D\u0443\u043B\u043E \u0441\u043E\u043E\u0431\u0449\u0435\u043D\u0438\u0435:
    \u041D\u041E\u0412\u042B\u0419 \u0420\u0415\u041A\u041E\u0420\u0414: 4 275 \u041C..
    \u0420\u0430\u0434\u043E\u0441\u0442\u044C \u0441\u043C\u0435\u043D\u0438\u043B\u0430\u0441\u044C
    \u0445\u043E\u043B\u043E\u0434\u043D\u044B\u043C \u043E\u0441\u043E\u0437\u043D\u0430\u043D\u0438\u0435\u043C.
    \u041F\u043B\u0430\u043D\u0435\u0442\u0430 \u0441\u0438\u044F\u043B\u0430 \u0442\u0430\u043A
    \u0431\u043B\u0438\u0437\u043A\u043E, \u043D\u043E \u0432 \u0431\u0435\u0441\u043A\u0440\u0430\u0439\u043D\u0435\u043C
    \u043A\u043E\u0441\u043C\u043E\u0441\u0435 \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435
    \u043E\u0431\u043C\u0430\u043D\u0447\u0438\u0432\u043E. \u0412\u043F\u0435\u0440\u0435\u0434\u0438
    \u043B\u0435\u0436\u0430\u043B\u0438 \u043B\u0438\u0448\u044C \u043F\u0443\u0441\u0442\u043E\u0442\u0430
    \u0438 \u0437\u0432\u0435\u0437\u0434\u043D\u044B\u0439 \u0441\u0432\u0435\u0442.
    \u041C\u044B \u043F\u0440\u043E\u0440\u0432\u0430\u043B\u0438\u0441\u044C. \u041D\u043E
    \u0441\u043A\u043E\u043B\u044C\u043A\u043E \u0435\u0449\u0435 \u043B\u0435\u0442\u0435\u0442\u044C?
    \u0427\u0430\u0441? \u0414\u0435\u043D\u044C? \u0413\u043E\u0434? \u2014 \u043F\u0440\u043E\u043C\u0435\u043B\u044C\u043A\u043D\u0443\u043B\u0430
    \u043C\u044B\u0441\u043B\u044C. \u0420\u0435\u043A\u043E\u0440\u0434 \u0431\u044B\u043B
    \u043F\u043E\u0441\u0442\u0430\u0432\u043B\u0435\u043D. \u041D\u043E \u0444\u0438\u043D\u0430\u043B\u044C\u043D\u0430\u044F
    \u0447\u0435\u0440\u0442\u0430 \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0430\u0441\u044C
    \u0433\u0434\u0435-\u0442\u043E \u0442\u0430\u043C, \u0432\u043F\u0435\u0440\u0435\u0434\u0438,
    \u043D\u0435\u0432\u0438\u0434\u0438\u043C\u0430\u044F \u0438 \u043D\u0435\u0434\u043E\u0441\u0442\u0438\u0436\u0438\u043C\u0430\u044F.
    \u041F\u043E\u043B\u0435\u0442 \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u043B\u0441\u044F."
